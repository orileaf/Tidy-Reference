# Environment configuration — tidy-reference
# Copy this file to config.env and fill in your credentials:
#   cp config.env.example config.env
#   nano config.env

# ── Python interpreter for shell scripts ─────────────────────────────────────
# Optional. Shell scripts will fall back to `python3` if unset.
# On Windows / macOS, leave this commented out or set to just `python`.
# PIPTHON=/usr/bin/python3

# ── LLM: OpenAI-compatible API (required) ─────────────────────────────────────
# This tool uses the OpenAI SDK and works with any compatible API provider.
# Choose ONE of the following three keys based on your provider:
#
#   Option A — Aliyun DashScope (推荐 / recommended)
#     DASHSCOPE_API_KEY=your_key_here
#     OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#     OPENAI_MODEL=qwen-plus
#
#   Option B — OpenAI / Groq / etc.
#     OPENAI_API_KEY=your_key_here
#     OPENAI_BASE_URL=https://api.openai.com/v1  (or your provider's URL)
#     OPENAI_MODEL=gpt-4o-mini
#
#   Option C — Ollama (local)
#     OPENAI_API_KEY=any-value
#     OPENAI_BASE_URL=http://localhost:11434/v1
#     OPENAI_MODEL=llama3
#
# Priority: DASHSCOPE_API_KEY → OPENAI_API_KEY → ANTHROPIC_API_KEY

# Fill in your key here (uncomment and replace):
# DASHSCOPE_API_KEY=your_dashscope_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here

# Base URL and model — adjust to match your chosen provider above:
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=qwen-plus

# ── Anthropic (Claude) — optional fallback ────────────────────────────────────
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Crossref API (required) ───────────────────────────────────────────────────
# mailto is required by Crossref's terms of service — set any valid email
CROSSREF_MAILTO=your@email.com

# ── Semantic Scholar (optional) ───────────────────────────────────────────────
# Free; leave blank to use the public API (rate-limited, no key needed).
# Get a key at: https://www.semanticscholar.org/product/api
# SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_api_key_here

# ── MiniMax MCP — Step 4 web search fallback (optional) ──────────────────────
# MCP only activates when Steps 1–3 all return no results.
# To enable: install MiniMax MCP, set your key below, and configure .mcp.json.
# To disable: set DISABLE_MCP=1 (or run with --no-mcp flag)
# MINIMAX_API_KEY=your_minimax_api_key_here
# MINIMAX_API_HOST=https://api.minimaxi.com
# DISABLE_MCP=1

